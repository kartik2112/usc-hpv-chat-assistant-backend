{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Flask Dev Server",
      "runtimeExecutable": ".venv/bin/python",
      "runtimeArgs": ["flask_backend.py"],
      "port": 5000,
      "autoPort": true
    },
    {
      "name": "Gunicorn (Production)",
      "runtimeExecutable": "gunicorn",
      "runtimeArgs": ["flask_backend:app"],
      "port": 8000
    }
  ]
}
